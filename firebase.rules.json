{
  "rules": {
    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": "auth != null && auth.uid == $uid",
        "jobs": {
          "$jobId": {
            ".validate": "newData.hasChildren(['company', 'role', 'status', 'appliedDate'])"
          }
        }
      }
    }
  }
}